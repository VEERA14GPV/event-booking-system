# Base URL of the Spring Boot backend (no trailing slash).
# In dev, Vite proxies /auth, /events, /shows, /seats, /bookings, /payments, /socket
# to this target (see vite.config.js), so VITE_API_BASE_URL can stay relative ("").
VITE_API_BASE_URL=http://localhost:8082

# SockJS endpoint exposed by WebSocketConfig (spring.websocket.path in
# application.properties, currently set to "/socket").
VITE_WS_URL=http://localhost:8082/socket
