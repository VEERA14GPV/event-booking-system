# =========================================================
# Environment variable template for docker-compose.yml
# =========================================================
# Copy this file to .env and fill in real values before
# running docker-compose up.
#
#   cp .env.example .env
#
# The .env file is listed in .gitignore and must NEVER
# be committed to source control.
# =========================================================

# ---- MySQL ----
DB_USER=booking_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ---- JWT ----
# REQUIRED. No default — the application will refuse to start
# if this is not set (Spring will throw:
#   IllegalArgumentException: Could not resolve placeholder 'JWT_SECRET')
#
# jjwt 0.12.x (HS256) requires a minimum key length of 256 bits = 32 bytes.
# Keys shorter than 32 bytes cause:
#   WeakKeyException: The signing key's size is NNN bits which is not secure
#   enough for the HS256 algorithm.
#
# Generate a safe 64-byte (512-bit) key with:
#   openssl rand -hex 64
JWT_SECRET=replace_with_output_of___openssl_rand_-hex_64

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_real_secret
